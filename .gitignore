# ============================================
# DevOpsClaw .gitignore
# ============================================

# ============================================
# 1. 敏感配置文件
# ============================================
.env
.env.local
.env.*.local
.env.backup
.env.bak
.openclaw_token
.openclaw_token.bak
*.token
*.secret

# ============================================
# 2. 数据目录（包含密码、密钥等敏感信息）
# ============================================
data/
data/gitlab/
data/jenkins/
data/openclaw/

# ============================================
# 3. SSL 证书和私钥
# ============================================
*.key
*.pem
*.pfx
*.p12
deploy_nginx/nginx/ssl/*.key

# ============================================
# 4. 日志文件
# ============================================
*.log
deploy.log

# ============================================
# 5. 临时文件
# ============================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ============================================
# 6. Python 相关
# ============================================
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
dist/
build/
.eggs/
*.egg

# ============================================
# 7. IDE 和编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# 8. 测试相关
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.coverage.*
.coverage
*.cover
.hypothesis/
.pytest_cache/

# 测试报告（每次运行都会生成，不应该提交）
tests/*_test_report.txt
tests/*.report
tests/report*.txt

# 测试输出目录
tests/output/
tests/results/

# ============================================
# 9. 自愈功能状态文件
# ============================================
.self-heal-state.json

# ============================================
# 10. 其他敏感文件
# ============================================
*.backup
*.old
*.orig
*.rej

# ============================================
# 注意：以下文件可以提交到代码仓库
# ============================================
# .env.example     - 环境变量示例模板
# deploy_nginx/nginx/ssl/*.crt  - SSL 证书（公钥，可提交）
# 但 *.key 是私钥，绝对不能提交！

config/.global_settings.yaml
# ============================================
# DevOpsClaw 环境变量配置文件
# ============================================
# 复制此文件为 .env 并填入实际值
#
# Linux/Mac:  cp .env.example .env
# Windows:    copy .env.example .env
#
# ============================================
# 重要提示
# ============================================
# 1. 所有包含 "your_*_here" 的值都需要替换为实际值
# 2. 以 "#" 开头的行是注释，可以根据需要取消注释
# 3. 端口配置需要与 docker-compose.yml 保持一致
#

# ============================================
# 1. 项目基础配置
# ============================================

# 项目名称（用于 Docker 资源命名前缀）
COMPOSE_PROJECT_NAME=devopsclaw

# Docker 网络名称
DOCKER_NETWORK=devopsclaw-network

# ============================================
# 2. OpenClaw 配置 (必需)
# ============================================

# OpenClaw Gateway Token
# 用于 OpenClaw API 认证和设备配对
#
# 生成方式:
#   Linux/Mac:  tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 64
#   Windows PowerShell:
#     -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 64 | ForEach-Object {[char]$_})
#
# 安全提示:
#   - Token 长度建议 64 字符以上
#   - 不要在代码仓库中提交真实的 Token
#   - 定期更换 Token
OPENCLAW_GATEWAY_TOKEN=your_secure_gateway_token_here

# OpenClaw 容器名称
OPENCLAW_CONTAINER_NAME=devopsclaw-openclaw

# OpenClaw 端口
# 注意: 修改此端口需要同时修改 docker-compose.yml
OPENCLAW_PORT=18789

# OpenClaw 镜像
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ============================================
# 3. Jenkins 配置
# ============================================

# Jenkins 访问地址
# 容器内访问: http://devopsclaw-jenkins:8080/jenkins
# 宿主机访问: http://127.0.0.1:8081/jenkins
#
# 注意:
#   - 如果部署在远程服务器，请修改为实际的 IP 或域名
#   - 路径前缀 /jenkins 需要与 docker-compose.yml 中的 JENKINS_OPTS 保持一致
JENKINS_URL=http://127.0.0.1:8081/jenkins

# Jenkins 管理员用户名
# 首次启动时创建的管理员用户
JENKINS_USER=admin

# Jenkins API Token
# 用于 Jenkins API 认证（JJB、Webhook 等）
#
# 获取方式:
#   1. 登录 Jenkins Web UI
#   2. 点击右上角用户名 → 设置
#   3. 找到 "API Token" 部分
#   4. 点击 "添加新 Token"
#   5. 输入名称（如 "devopsclaw"）
#   6. 点击 "生成" 并复制 Token（仅显示一次！）
#
# 注意: 此 Token 部署后才能获取，可以先留空，部署完成后再填写
JENKINS_TOKEN=your_jenkins_api_token_here

# Jenkins 容器名称
JENKINS_CONTAINER_NAME=devopsclaw-jenkins

# Jenkins Web 端口（宿主机）
# 注意: 修改此端口需要同时修改 docker-compose.yml
JENKINS_PORT_WEB=8081

# Jenkins Agent 端口（宿主机）
# 用于 Jenkins Agent 连接
JENKINS_PORT_AGENT=50000

# Jenkins 镜像
JENKINS_IMAGE=jenkins/jenkins:lts-jdk17

# Jenkins JVM 内存配置
# 根据服务器实际内存调整
# 格式: -Xmx<最大内存> -Xms<初始内存>
JENKINS_JAVA_OPTS=-Xmx2g -Xms512m

# ============================================
# 4. GitLab 配置 (可选)
# ============================================

# 是否启用 GitLab
# 设置为 true 时部署 GitLab，false 时跳过
GITLAB_ENABLED=true

# GitLab 主机名
# 用于配置 external_url
# 如果部署在远程服务器，请修改为实际的域名或 IP
GITLAB_HOSTNAME=gitlab.devopsclaw.local

# GitLab 容器名称
GITLAB_CONTAINER_NAME=devopsclaw-gitlab

# GitLab HTTP 端口（宿主机）
GITLAB_PORT_HTTP=8082

# GitLab HTTPS 端口（宿主机）
GITLAB_PORT_HTTPS=8443

# GitLab SSH 端口（宿主机）
GITLAB_PORT_SSH=2222

# GitLab 镜像
GITLAB_IMAGE=gitlab/gitlab-ce:latest

# GitLab 共享内存大小
# GitLab 需要足够的共享内存
# 单位: m (MB) 或 g (GB)
GITLAB_SHM_SIZE=512m

# ============================================
# 5. AI 模型配置 (可选)
# ============================================

# 默认使用的 AI 模型
# 此配置用于自愈功能中的 AI 诊断
#
# 可选值:
#   - deepseek-reasoner (推荐)
#     * 推理质量高，擅长解决复杂问题
#     * 适合代码修复、错误诊断
#
#   - kimi-k2.5
#     * 响应速度快
#     * 适合简单问题快速诊断
#
#   - 其他自定义模型
#     * 格式: custom-api-<provider>/<model-name>
#     * 例如: custom-api-openai-com/gpt-4
DEFAULT_MODEL=deepseek-reasoner

# DeepSeek API Key (如果使用 DeepSeek)
# 注意: 仅在需要直接调用 DeepSeek API 时配置
# 默认情况下通过 OpenClaw 调用，不需要此配置
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Kimi API Key (如果使用 Kimi)
# KIMI_API_KEY=your_kimi_api_key_here

# ============================================
# 6. 自愈功能配置 (可选)
# ============================================

# 最大自愈重试次数
# 当构建失败后，自动修复的最大尝试次数
# 达到此次数后，停止自动修复，等待人工介入
#
# 建议值: 3-5
# - 太小可能无法修复复杂问题
# - 太大可能浪费资源或引入新问题
MAX_RETRY=5

# 自愈状态文件路径
# 用于存储自愈过程中的状态信息
# 相对路径或绝对路径
SELF_HEAL_STATE_FILE=.self-heal-state.json

# 是否启用自愈功能
# 设置为 false 可以禁用自动修复
SELF_HEAL_ENABLED=true

# ============================================
# 7. JJB (Jenkins Job Builder) 配置 (可选)
# ============================================

# JJB 配置文件存放路径
# 相对于项目根目录的路径，或绝对路径
#
# 此目录应包含:
#   - jenkins_jobs.ini: JJB 连接配置
#   - defaults.yaml: 全局默认配置
#   - *.yaml: 各个 Job 的定义
JJB_CONFIG_PATH=./jjb-configs

# JJB 配置文件名
JJB_INI_FILE=jenkins_jobs.ini

# 是否自动部署 JJB 配置
# 设置为 true 时，部署完成后自动执行 jenkins-jobs update
JJB_AUTO_UPDATE=false

# ============================================
# 8. Webhook 配置 (可选)
# ============================================

# Webhook Listener 端口
# 用于接收 Jenkins 的构建事件通知
#
# 注意:
#   - 此端口在宿主机上运行（非 Docker 容器）
#   - 仅在使用 webhook_listener.py 时需要
WEBHOOK_PORT=5000

# Webhook 绑定地址
# 127.0.0.1 表示仅本地访问
# 0.0.0.0 表示允许外部访问（不推荐，除非有防火墙保护）
WEBHOOK_BIND_ADDRESS=127.0.0.1

# ============================================
# 9. 日志和调试配置 (可选)
# ============================================

# 日志级别
# 可选值: DEBUG, INFO, WARN, ERROR
#
# DEBUG: 详细的调试信息
# INFO:  一般信息（默认）
# WARN:  警告信息
# ERROR: 错误信息
LOG_LEVEL=INFO

# 是否启用详细日志
# 设置为 true 时输出更详细的日志
DEBUG_MODE=false

# ============================================
# 10. Docker 配置 (可选)
# ============================================

# Docker 镜像加速地址
# 国内用户可以配置镜像加速，提高拉取速度
#
# 常用镜像源:
#   - https://docker.1ms.run
#   - https://docker.xuanyuan.me
#   - https://registry.docker-cn.com
#   - https://docker.mirrors.ustc.edu.cn
#
# 注意: 此配置仅用于部署脚本提示，实际配置在 /etc/docker/daemon.json
# DOCKER_MIRROR=https://docker.1ms.run

# 是否自动拉取最新镜像
# 设置为 true 时，每次部署都会拉取最新镜像
DOCKER_PULL_LATEST=true

# ============================================
# 11. 安全配置 (可选)
# ============================================

# 是否允许外部访问
# 设置为 true 时，端口绑定到 0.0.0.0（所有接口）
# 设置为 false 时，端口绑定到 127.0.0.1（仅本地）
#
# 安全建议:
#   - 开发环境: false（仅本地访问）
#   - 生产环境: false + Nginx 反向代理
#   - 永远不要直接将服务暴露到公网
ALLOW_EXTERNAL_ACCESS=false

# ============================================
# 12. Nginx 反向代理配置 (可选，v4.1.0 新增)
# ============================================
#
# 启用 Nginx 后：
#   - 所有 Web 流量通过 Nginx 统一入口
#   - 后端服务（Jenkins、GitLab、OpenClaw）不直接暴露端口
#   - 统一 SSL 证书管理
#   - 统一访问日志
#
# 注意: 启用 Nginx 需要先生成 SSL 证书
#   运行: ./deploy_nginx/generate_certs.sh

# 是否启用 Nginx 反向代理
# 设置为 true 时，后端服务端口不直接暴露，仅通过 Nginx 访问
NGINX_ENABLED=false

# Nginx 容器名称
NGINX_CONTAINER_NAME=devopsclaw-nginx

# Nginx 镜像
NGINX_IMAGE=nginx:alpine

# Nginx 绑定地址
# 0.0.0.0 表示所有接口（外部可访问）
# 127.0.0.1 表示仅本地访问
NGINX_BIND=0.0.0.0

# ============================================
# Nginx 端口配置（Web 服务通过 Nginx 访问）
# ============================================
# 这些是 Nginx 监听的端口，用于 HTTPS 访问
# 后端服务的 HTTP 端口不直接暴露

# GitLab HTTPS 端口
# Nginx 监听端口，转发到 gitlab:80
NGINX_PORT_GITLAB=8929

# Jenkins HTTPS 端口
# Nginx 监听端口，转发到 jenkins:8080
NGINX_PORT_JENKINS=8080

# OpenClaw HTTPS 端口
# Nginx 监听端口，转发到 openclaw:18789
NGINX_PORT_OPENCLAW=18789

# Harbor HTTPS 端口（可选）
# Nginx 监听端口，转发到 harbor:8080
NGINX_PORT_HARBOR=8443

# Artifactory HTTPS 端口（可选）
# Nginx 监听端口，转发到 artifactory:8082
NGINX_PORT_ARTIFACTORY=8081

# TRM HTTPS 端口（可选）
# Nginx 监听端口，转发到 trm:8080
NGINX_PORT_TRM=8085

# RabbitMQ 管理界面 HTTPS 端口（可选）
# Nginx 监听端口，转发到 rabbitmq:15672
NGINX_PORT_RABBITMQ=15672

# ============================================
# 配置说明
# ============================================
#
# 【必需配置】部署前必须填写:
#   - OPENCLAW_GATEWAY_TOKEN
#
# 【部署后配置】部署完成后需要填写:
#   - JENKINS_TOKEN（从 Jenkins 获取）
#
# 【可选配置】根据实际需求修改:
#   - 所有其他配置项
#
# 【端口配置参考】
#
# v4.0.0 模式（无 Nginx，本地绑定）:
#   服务        宿主机端口  容器端口  绑定地址    说明
#   OpenClaw    18789       18789    127.0.0.1   AI 网关
#   Jenkins     8081        8080     127.0.0.1   Web UI
#   Jenkins     50000       50000    127.0.0.1   Agent 连接 (TCP 直连)
#   GitLab      8082        80       127.0.0.1   HTTP
#   GitLab      8443        443      127.0.0.1   HTTPS
#   GitLab      2222        22       127.0.0.1   SSH (TCP 直连)
#   Webhook     5000        5000     127.0.0.1   本地服务
#
# v4.1.0 模式（带 Nginx 反向代理）:
#
#   Nginx 监听端口（外部可访问，HTTPS）:
#   端口      转发到后端      说明
#   443       gitlab:80      默认 HTTPS (可配置)
#   8929      gitlab:80      GitLab
#   8080      jenkins:8080   Jenkins
#   18789     openclaw:18789 OpenClaw
#   8443      harbor:8080    Harbor (可选)
#   8081      artifactory:8082 Artifactory (可选)
#   8085      trm:8080       TRM (可选)
#   15672     rabbitmq:15672 RabbitMQ 管理 (可选)
#
#   TCP 直连端口（不经过 Nginx）:
#   端口      服务            说明
#   2222      GitLab SSH      Git 命令行操作
#   50000     Jenkins Agent   Jenkins 主从通信

# 【修改端口后需要同步修改的文件】
#   1. docker-compose.yml (ports 部分)
#   2. .env (此文件)
#   3. doc/9deploy_ci_tool.md (文档)
#   4. deploy_nginx/nginx/conf.d/*.conf (Nginx 配置)
